#!/usr/bin/env python3
"""scorch — read the latest live Claude-usage snapshot and tell you whether to burn.

Reads the snapshot the statusline caches at ~/.claude/scorched-earth/state.json so it
works in any terminal. Pass --weekly-left / --window etc. to compute manually when
you're outside a Claude Code session (or to fill a gap before calibration kicks in).
"""

from __future__ import annotations

import argparse
import os
import re
import sys
import time

# Resolve the repo's src/ regardless of where `scorch` is symlinked from.
_REPO = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
sys.path.insert(0, os.path.join(_REPO, "src"))

from scorched_earth.core import Snapshot, compute, HEADLINE  # noqa: E402
from scorched_earth import state as st  # noqa: E402
from scorched_earth import calibrate  # noqa: E402
from scorched_earth import gradient  # noqa: E402
from scorched_earth import habits  # noqa: E402
import math  # noqa: E402

LIGHT = {"max": "🔥", "push": "🟢", "steady": "⚪", "ease": "⚠️", "done": "🎖️", "unknown": "❔"}
COLOR = {"max": "\033[1;31m", "push": "\033[1;32m", "steady": "\033[1;37m",
         "ease": "\033[1;33m", "done": "\033[1;35m", "unknown": "\033[2m"}
RESET = "\033[0m"
# HEADLINE (war-general verdict per status) is imported from core so the CLI and the HTML
# sitrep stay in lockstep.


NO_DATA = (
    "\n  Nothing to read yet.\n"
    "  Open a Claude Code session so the statusline can grab a\n"
    "  reading, or do the math by hand:\n\n"
    "    scorch --weekly-left 62 --weekly-reset 11h --window 80 --window-reset 1h\n"
)


def c(s, level, on):
    return f"{COLOR.get(level,'')}{s}{RESET}" if on else s


def _has_usable_snapshot(state) -> bool:
    snap = (state or {}).get("snapshot") or {}
    return snap.get("seven_day_pct") is not None


def _open_file(path) -> None:
    """Open a file in the OS default app. macOS `open`, Linux `xdg-open`; otherwise no-op."""
    import shutil
    import subprocess
    opener = "open" if sys.platform == "darwin" else ("xdg-open" if shutil.which("xdg-open") else None)
    if opener:
        subprocess.run([opener, path], check=False)


def _roe_editor(repo) -> int:
    """Interactive ROE editor: an arrow-key list, like Claude's permissions UI. up/down move,
    left/right change a cycle, space/enter flips a toggle, s saves, q quits. Curses is just the
    view; all edit logic lives in the pure roe_edit model."""
    import curses
    from scorched_earth import coa_io, roe_edit

    def run(scr):
        curses.curs_set(0)
        scr.keypad(True)                 # decode arrow keys to curses.KEY_* (not raw ESC sequences)
        try:
            curses.use_default_colors()
        except Exception:
            pass
        roe = coa_io.load_roe(repo)
        sel, dirty, msg = 0, False, ""
        name = os.path.basename(os.path.realpath(os.path.expanduser(repo)))
        while True:
            ctrls = roe_edit.controls(roe)
            scr.erase()
            h, w = scr.getmaxyx()

            def put(y, text, attr=0):
                # Bounded draw: a terminal shorter than the control list (or a resize
                # mid-session) must scroll the list off, never crash curses.
                if 0 <= y < h and w > 1:
                    try:
                        scr.addnstr(y, 0, text, w - 1, attr)
                    except curses.error:
                        pass

            put(0, (f" RULES OF ENGAGEMENT  {name} ").ljust(w - 1), curses.A_REVERSE)
            put(1, " up/down move   left/right change   space toggle   s save   q quit")
            row = 3
            for i, c in enumerate(ctrls):
                mark = ("[x]" if c.on else "[ ]") if c.kind == "toggle" else f"< {c.value} >"
                line = ("  " + mark.ljust(10) + "  " + c.label).ljust(w - 1)
                put(row, line, curses.A_REVERSE if i == sel else curses.A_NORMAL)
                row += 1
            if 0 <= sel < len(ctrls):
                put(row + 1, "  " + ctrls[sel].help, curses.A_DIM)
            foot = msg or ("UNSAVED CHANGES (press s to save)" if dirty else "")
            if foot:
                put(h - 1, ("  " + foot).ljust(w - 1), curses.A_BOLD)
            scr.refresh()

            k = scr.getch()
            msg = ""
            if k in (curses.KEY_UP, ord("k")):
                sel = (sel - 1) % len(ctrls)
            elif k in (curses.KEY_DOWN, ord("j")):
                sel = (sel + 1) % len(ctrls)
            elif k in (curses.KEY_LEFT, ord("h")):
                roe = roe_edit.apply(roe, sel, -1); dirty = True
            elif k in (curses.KEY_RIGHT, ord("l")):
                roe = roe_edit.apply(roe, sel, +1); dirty = True
            elif k in (ord(" "), 10, 13, curses.KEY_ENTER):
                roe = roe_edit.apply(roe, sel, 0); dirty = True
            elif k in (ord("s"), ord("S")):
                roe_edit.save(repo, roe); dirty = False; msg = "saved to .scorched/roe.json"
            elif k in (ord("q"), ord("Q")):   # not ESC: arrow keys begin with ESC and would quit
                return

    curses.wrapper(run)
    print(f"ROE editor closed for {os.path.realpath(os.path.expanduser(repo))}")
    return 0


def _serve_shell(repos, tab="sitrep") -> int:
    """Launch the unified War Room shell: one 127.0.0.1 token-guarded server hosting the big-tab
    frame (SITREP / COURSE OF ACTION / WAR ROOM). `tab` sets the tab the browser opens on. The
    War Room tab starts paused (stage the queue, then Run). Blocks on serve_forever."""
    import secrets
    import webbrowser
    from scorched_earth import coa_serve
    token = secrets.token_urlsafe(32)
    engine = coa_serve.Engine(repos)
    engine.stop()       # War Room starts PAUSED: stage/organize the queue first, then Run
    httpd, port = coa_serve.make_server(engine, token, render=coa_serve.render_cockpit,
                                        shell_repos=repos)
    frag = f"#{tab}" if tab else ""
    url = f"http://127.0.0.1:{port}/?t={token}{frag}"
    print(f"War Room on {url}\n(Ctrl-C to stop)", flush=True)
    try:
        webbrowser.open(url)
    except Exception:
        pass
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\nWar Room stopped.")
    return 0


def parse_when(val):
    """Accept '11h', '90m', '1h30m', '1d', or a raw unix timestamp -> unix seconds."""
    if val is None:
        return None
    val = val.strip()
    if re.fullmatch(r"\d{9,}", val):  # looks like a unix timestamp
        return int(val)
    secs = 0
    matched = False
    for amount, unit in re.findall(r"(\d+)\s*([dhms])", val):
        matched = True
        secs += int(amount) * {"d": 86400, "h": 3600, "m": 60, "s": 1}[unit]
    if not matched:
        raise argparse.ArgumentTypeError(f"can't parse time '{val}' (try 11h, 90m, 1h30m)")
    return int(time.time()) + secs


def fmt_dur(seconds):
    if seconds is None:
        return "-"
    seconds = max(0, int(seconds))
    d, rem = seconds // 86400, seconds % 86400
    h, m = rem // 3600, (rem % 3600) // 60
    if d:
        return f"{d}d {h}h" if h else f"{d}d"
    if h and m:
        return f"{h}h {m}m"
    if h:
        return f"{h}h"
    return f"{m}m"


def render_forecast(fc, on):
    if not fc or fc.get("projected_end_used") is None:
        return ""
    end = fc["projected_end_used"]
    left = fc.get("projected_leftover") or 0.0
    conf = fc.get("confidence", "none")
    lines = [
        f"  Intel: hold this pace and you finish at ~{end:.0f}% used, "
        f"with {left:.0f}% left to rot at reset · {conf} confidence"
    ]
    if fc.get("basis", "").startswith("linear"):
        lines.append("  ↳ still learning your weekly rhythm. It gets sharper over a few weeks.")
    if fc.get("preemptive"):
        msg = "⚠️ At this pace you'll forfeit reserves at reset. Advance harder."
        lines.append(f"  {c(msg, 'amber', on)}")
    return "\n".join(lines)


def render(snap, rec, on, provisional_hint=True, fc=None):
    out = []
    level = rec.level
    out.append("")
    out.append(f"  {c('SCORCHED EARTH', level, on)}  {LIGHT.get(level,'')}  {c(HEADLINE[level], level, on)}")
    out.append("")
    if rec.weekly_left is not None:
        wr = (snap.seven_day_reset - snap.now) if snap.seven_day_reset else None
        out.append(f"  Weekly:   {rec.weekly_left:.0f}% left   ↺ resets in {fmt_dur(wr)}")
    if snap.five_hour_pct is not None:
        hr = (snap.five_hour_reset - snap.now) if snap.five_hour_reset else None
        out.append(f"  Window:   {snap.five_hour_pct:.0f}% used   ↺ resets in {fmt_dur(hr)}")
    if rec.windows_left is not None:
        out.append(f"  Windows left before weekly reset: ~{rec.windows_left:.1f}")
    if rec.burn_pct is not None:
        out.append(f"  Recommended burn: {c(f'{rec.burn_pct:.0f}% per window', level, on)}")
    out.append("")
    out.append(f"  {rec.reason}")
    fc_block = render_forecast(fc, on)
    if fc_block:
        out.append("")
        out.append(fc_block)
    if rec.r is not None:
        tag = "measured" if not rec.r_provisional else "still calibrating"
        out.append(f"  Each of your ~{rec.windows_left:.0f} remaining windows is worth "
                   f"~{rec.r * 100:.0f}% of your weekly budget · {tag}")
        if rec.r_provisional and provisional_hint:
            out.append("  ↳ keep using Claude and this sharpens on its own")
    out.append("")
    return "\n".join(out)


def fire_demo():
    """Animate the fire-gradient token in this terminal so the flow is actually visible
    (the statusline can only refresh at Claude Code's cadence)."""
    tc = gradient.supports_truecolor()
    if not sys.stdout.isatty():
        # Non-interactive: print a few static frames so the effect is still inspectable.
        for k in range(3):
            print("  🔥 " + gradient.fire("BURN IT ALL", phase=k * 1.1))
        return 0
    label = "truecolor" if tc else "256-color (set COLORTERM=truecolor for full range)"
    sys.stdout.write(f"\033[?25l")  # hide cursor
    try:
        print(f"\n  fire-demo · {label} · Ctrl-C to stop\n")
        while True:
            phase = (time.time() * 2.4) % (2 * math.pi)
            line = "  🔥 " + gradient.fire("BURN IT ALL", phase=phase)
            sys.stdout.write("\r\033[K" + line)
            sys.stdout.flush()
            time.sleep(0.05)
    except KeyboardInterrupt:
        pass
    finally:
        sys.stdout.write("\033[?25h\n")  # show cursor
        sys.stdout.flush()
    return 0


def _coa_cli(raw):
    import json as _json
    from scorched_earth import coa_io, advisor, coa_report
    verb, rest = raw[0], raw[1:]

    if verb in ("link", "unlink"):
        if not rest:
            print(f"usage: scorch {verb} <repo-path>")
            return 2
        if verb == "link":
            print(f"Linked {coa_io.link_repo(rest[0])}")
        else:
            print("Unlinked." if coa_io.unlink_repo(rest[0]) else "Not linked.")
        return 0

    if verb == "roe":
        import dataclasses as _dc
        named = [a for a in rest if not a.startswith("-")]
        repo = named[0] if named else "."
        if "--web" in rest:
            # The served editor: the shell opened on the RULES OF ENGAGEMENT tab (all linked
            # repos, or just the named one). This is what /roe launches, since a slash command
            # has no tty for the curses editor.
            repos = [repo] if named else (coa_io.list_repos() or [repo])
            return _serve_shell(repos, tab="roe")
        # Interactive editor when we own a real terminal; JSON fallback for pipes/scripts/--json.
        if "--json" in rest or not sys.stdout.isatty():
            print(_json.dumps(_dc.asdict(coa_io.load_roe(repo)), indent=2))
            return 0
        return _roe_editor(repo)

    # advise
    state = st.load_state()
    snap = (state or {}).get("snapshot") or {}
    rec = (state or {}).get("recommendation") or {}
    if not _has_usable_snapshot(state):
        print("No live budget reading yet, so there's nothing to plan against. "
              "Open a Claude Code session to capture a snapshot, then try again.")
        return 0
    no_open = "--no-open" in rest
    serve = "--serve" in rest
    rest = [a for a in rest if a not in ("--no-open", "--serve")]
    repos = [rest[0]] if rest else coa_io.list_repos()
    if not repos:
        print("No repos linked. Use: scorch link <path>")
        return 0

    # --serve: open the unified War Room shell on its COURSE OF ACTION tab (the read-only COA,
    # per-repo tabs + Refresh that re-reads jobs.json, no repo re-scan). One server, one token.
    if serve:
        return _serve_shell(repos, "coa")

    date = time.strftime("%Y-%m-%d", time.localtime())
    wrp = advisor.weekly_reserve_pct(snap) or 0.0
    level = rec.get("level", "unknown")
    # Weekly reset countdown (display context for the HTML report).
    wr = snap.get("seven_day_reset")
    reset_in = fmt_dur(wr - snap.get("now", int(time.time()))) if wr else ""
    # Collect only repos that actually have jobs — never write/open a blank report (the timing trap
    # where advise runs before the scan has populated jobs.json).
    repo_coas = []
    for repo in repos:
        roe = coa_io.load_roe(repo)
        coa = advisor.match(coa_io.load_jobs(repo), roe)
        print(f"\n=== {repo} ===")
        if not coa.queue and not coa.blocked:
            print("No jobs found yet. Run the scan first (/coa), then advise. (Skipping a blank report.)")
            continue
        print(coa.note)
        for j in coa.queue:
            mark = " (approval required)" if advisor.approval_required(j, roe) else ""
            print(f"  DEFCON {j.defcon}  {j.title or j.id}{mark}")
        repo_coas.append((repo, coa))
    if not repo_coas:
        print("\nNothing to report: no jobs in any linked repo yet. Scan first with /coa.")
        return 0
    # One combined, tabbed HTML across every repo with jobs; keep the per-repo md as the record.
    html = coa_report.render_html(None, date, repos=repo_coas, verdict=level,
                                  reset_in=reset_in, weekly_reserve_pct=wrp)
    written = []
    for repo, coa in repo_coas:
        md = coa_report.render_md(coa, date)
        _md_path, html_path = coa_io.write_coa(repo, md, html, date)
        written.append(html_path)
        print(f"COA written: {html_path}")
    if not no_open and written:
        _open_file(written[0])
    return 0


def _default_repo():
    """The repo to fall back to when none is named on the command line: prefer the CWD if it's
    already a linked repo (or has a .scorched dir), else the first linked repo, else '.'."""
    from scorched_earth import coa_io
    cwd = os.getcwd()
    if os.path.isdir(os.path.join(cwd, ".scorched")) or os.path.realpath(cwd) in coa_io.list_repos():
        return cwd
    repos = coa_io.list_repos()
    return repos[0] if repos else "."


def _coa_attended(args):
    """`scorch coa run <--here|--session> <job-id> [repo]` — run ONE job attended (Phase 3/4).
    --here takes over THIS window (execvp; does not return); --session spawns a new window.
    Resolves the repo + job, then dispatches to the exec_modes launcher."""
    from scorched_earth import coa_io, exec_modes
    flag = "--here" if "--here" in args else "--session"
    override = "takeover" if flag == "--here" else "session"
    i = args.index(flag)
    job_id = args[i + 1] if i + 1 < len(args) and not args[i + 1].startswith("-") else None
    if not job_id:
        print(f"Usage: scorch coa run {flag} <job-id> [repo]")
        return 0
    positional = [a for a in args if not a.startswith("-") and a != job_id]
    repo = next((a for a in positional if os.path.isdir(os.path.expanduser(a))), None) \
        or _default_repo()
    roe = coa_io.load_roe(repo)
    job = {j.id: j for j in coa_io.load_jobs(repo)}.get(job_id)
    if job is None:
        print(f"No job '{job_id}' in {repo}. Scan first with /coa.")
        return 0
    if override == "takeover":
        print(f"Taking over this window for job '{job_id}' in {repo} (Ctrl-C to abort)...")
        exec_modes.run_takeover(repo, job, roe)     # execvp: does not return on success
        return 0
    print(f"Opening a new session for job '{job_id}' in {repo}...")
    return exec_modes.run_session(repo, job, roe)


def _coa_resume(args):
    """`scorch coa resume <job-id> [repo]` — continue a roadblocked headless job (Phase 3 #11).
    Reuses the kept worktree/branch, feeds the roadblock report back in as context, re-runs the
    gate, and records a fresh deliverable (or a new roadblock report if it stalls again)."""
    import time as _t
    from scorched_earth import coa_io, runner
    ids = [a for a in args if not a.startswith("-")]
    if not ids:
        print("Usage: scorch coa resume <job-id> [repo]")
        return 0
    job_id = ids[0]
    repo = next((a for a in ids[1:] if os.path.isdir(os.path.expanduser(a))), None) \
        or _default_repo()
    job = {j.id: j for j in coa_io.load_jobs(repo)}.get(job_id)
    if job is None:
        print(f"No job '{job_id}' in {repo}.")
        return 0
    state = st.load_state()
    if runner.is_stale(state, int(_t.time())):
        print("No fresh budget snapshot. Open a Claude Code session, then resume.")
        return 0
    rpath = coa_io.roadblock_path(repo, job_id)
    report = open(rpath).read() if os.path.exists(rpath) else ""
    job.launch = ("You are RESUMING a job that hit a roadblock. Prior roadblock report:\n\n"
                  + report + "\n\nThe partial work is on branch " + runner.branch_name(job_id)
                  + " (checked out in this worktree). Continue from there and finish.\n\n"
                  + (job.launch or job.title))
    outcome, diff, note = runner.execute_job(repo, job, coa_io.load_roe(repo), resume=True)
    repo_disp = os.path.realpath(os.path.expanduser(repo))
    oc = runner.JobOutcome(seq=0, id=job_id, title=job.title, type=job.type, defcon=job.defcon,
                           outcome=outcome, diff=diff, note=note, branch=runner.branch_name(job_id),
                           merge_cmd=runner.merge_cmd(repo_disp, job_id),
                           discard_cmd=runner.discard_cmd(repo_disp, job_id))
    if outcome == "roadblocked":
        runner.handle_roadblock(repo, oc)
    else:
        runner.write_job_deliverable(repo, oc)
    print(f"{repo}: {job_id} resume -> {outcome}. {note}")
    return 0


def _coa_run_cli(rest):
    """`scorch coa <queue|run|review> …` — the Phase 2 queue-runner surface."""
    import time as _time
    from scorched_earth import coa_io, advisor, runner
    sub = rest[0] if rest else "review"
    args = rest[1:]
    date = _time.strftime("%Y-%m-%d", _time.localtime())

    if "--serve" in rest or sub == "serve":
        named = [a for a in rest if not a.startswith("-") and a != "serve"]
        repos = [named[0]] if named else coa_io.list_repos()
        if not repos:
            print("No repos linked. Use: scorch link <path>")
            return 0
        return _serve_shell(repos, "war-room")   # the unified shell, opened on the live cockpit tab

    if sub == "queue":
        all_flag = "--all" in args
        ids = [a for a in args if not a.startswith("-")]
        repo = ids.pop(0) if ids and os.path.isdir(os.path.expanduser(ids[0])) else "."
        state = st.load_state()
        # The runner halts on the real usage limit, not a budget gate; but we still need a live
        # snapshot to plan against, so refuse cleanly if there isn't one yet.
        if not _has_usable_snapshot(state):
            print("No live budget reading yet. Open a Claude Code session, then queue.")
            return 0
        roe = coa_io.load_roe(repo)
        coa = advisor.match(coa_io.load_jobs(repo), roe)
        if not all_flag and not ids:
            print("Nothing specified. Use `scorch coa queue --all` or pass job ids.")
            return 0
        pick = coa.queue if all_flag else [j for j in coa.queue if j.id in ids]
        if not pick:
            print("Nothing to queue (the latest COA produced no eligible jobs).")
            return 0
        q = coa_io.enqueue(repo, pick)
        print(f"Queued {len(pick)} job(s); {len(q)} in {repo}/.scorched/queue.json.")
        return 0

    if sub == "resume":
        return _coa_resume(args)

    if sub == "run":
        # --here <job-id> takes over THIS window (attended, sandboxed); --session <job-id> spawns
        # a new window (attended, free). Both are single-job; plain `run` drains headless.
        if "--here" in args or "--session" in args:
            return _coa_attended(args)
        approve = "--approve" in args
        repos = [a for a in args if not a.startswith("-")] or coa_io.list_repos() or ["."]
        state = st.load_state()
        now = int(_time.time())
        if runner.is_stale(state, now):
            print("No fresh budget snapshot. Open a Claude Code session so the statusline "
                  "captures a reading, then run again. (The runner can't read usage live.)")
            return 0
        for repo in repos:
            if not coa_io.read_queue(repo):
                continue
            rr = runner.run_queue(repo, state, now=now, date=date, approved=approve)
            if rr is None:
                print(f"{repo}: refused (stale snapshot).")
                continue
            html = os.path.join(coa_io.runs_dir(repo), f"{date}.html")
            print(f"{repo}: {rr.note}")
            _open_file(html)
        return 0

    # review (default)
    repo = (args[0] if args and os.path.isdir(os.path.expanduser(args[0])) else
            (coa_io.list_repos()[0] if coa_io.list_repos() else "."))
    if "--merge" in args or "--discard" in args:
        flag = "--merge" if "--merge" in args else "--discard"
        idx = args.index(flag)
        if idx + 1 >= len(args):                       # no id after the flag: clean refusal
            print(f"Usage: scorch coa review {flag} <job-id>")
            return 0
        jid = args[idx + 1]
        cmd = (runner.merge_cmd(repo, jid) if flag == "--merge"
               else runner.discard_cmd(repo, jid))
        print(f"Run this to {flag[2:]} {jid}:\n  {cmd}")
        return 0
    rec = coa_io.read_run_record(repo)
    if not rec:
        print("No run on record yet. Queue jobs (scorch coa queue) then run (scorch coa run).")
        return 0
    html = os.path.join(coa_io.runs_dir(repo), f"{rec['generated_at']}.html")
    if os.path.exists(html):
        _open_file(html)
    print(f"Latest run: {rec.get('note', '')}")
    return 0


def main(argv=None):
    raw = sys.argv[1:] if argv is None else list(argv)
    if raw and raw[0] == "coa":
        return _coa_run_cli(raw[1:])
    if raw and raw[0] in ("link", "unlink", "advise", "roe"):
        return _coa_cli(raw)

    p = argparse.ArgumentParser(prog="scorch", description=__doc__.splitlines()[0])
    p.add_argument("--weekly-left", type=float, help="manual: %% of weekly budget remaining")
    p.add_argument("--weekly-reset", type=parse_when, help="manual: when weekly resets (e.g. 11h)")
    p.add_argument("--window", type=float, help="manual: %% of current 5h window used")
    p.add_argument("--window-reset", type=parse_when, help="manual: when 5h window resets (e.g. 1h)")
    p.add_argument("--r", type=float, help="manual: R to use for this calc only")
    p.add_argument("--set-r", type=float, help="persist a manual R into calibration and exit")
    p.add_argument("--style", choices=["emoji", "text", "minimal", "fire", "off"],
                   help="set the statusline light style and exit")
    p.add_argument("--fire-demo", action="store_true",
                   help="animate the fire-gradient BURN IT ALL in this terminal (Ctrl-C to stop)")
    p.add_argument("--report", "--sitrep", nargs="?", const="", metavar="PATH", dest="report",
                   help="write a stylized HTML sitrep (situation report) and open it")
    p.add_argument("--no-open", action="store_true", help="with --report, don't auto-open the file")
    p.add_argument("--watch", action="store_true", help="re-print every few seconds")
    p.add_argument("--no-color", action="store_true")
    args = p.parse_args(argv)

    on = (not args.no_color) and sys.stdout.isatty()

    if args.fire_demo:
        return fire_demo()

    if args.report is not None:
        from scorched_earth import report as rpt
        state = st.load_state()
        # Don't render a confident HUD full of fabricated 0%s before any real reading exists.
        if not _has_usable_snapshot(state):
            print(NO_DATA)
            return 0
        path = os.path.expanduser(args.report or os.path.join(st.STATE_DIR, "report.html"))
        os.makedirs(os.path.dirname(path) or ".", exist_ok=True)
        # Refresh R from the calibration samples so the report uses the current (guard-railed)
        # estimate, not whatever was cached in state.json by an earlier reading.
        r_fresh, prov_fresh = calibrate.estimate_r(st.load_calibration().get("samples", []))
        if state and isinstance(state.get("recommendation"), dict):
            state["recommendation"]["r"] = r_fresh
            state["recommendation"]["r_provisional"] = prov_fresh
        rpt.generate(state, st.load_history(), path, int(time.time()))
        print(f"Sitrep written to {path}")
        if not args.no_open:
            _open_file(path)
        return 0

    if args.set_r is not None:
        calib = st.load_calibration()
        calib["r"], calib["r_provisional"] = args.set_r, False
        st._write_json(st.CALIB_PATH, calib)
        print(f"Set R = {args.set_r:.3f}. It'll refine itself as more data lands.")
        return 0

    if args.style is not None:
        os.makedirs(st.STATE_DIR, exist_ok=True)
        with open(os.path.join(st.STATE_DIR, "style"), "w") as f:
            f.write(args.style)
        shown = {"emoji": "🔥 BURN IT ALL / 🟢 clear shot / ⚪ eyes on the target / ⚠️ hold your fire / 🎖️ good job",
                 "text": "colored words per state", "minimal": "one colored dot per state",
                 "fire": "🔥 animated BURN IT ALL (+ darts on eyes on the target)",
                 "off": "no statusline light"}[args.style]
        print(f"Light style set to '{args.style}'  ({shown}).")
        return 0

    # Manual mode: enough overrides to build a snapshot ourselves. If the user supplied some
    # manual inputs but not the required pair, say so instead of silently ignoring them.
    manual_given = any(v is not None for v in
                       (args.weekly_left, args.weekly_reset, args.window, args.window_reset))
    if manual_given and not (args.weekly_left is not None and args.weekly_reset is not None):
        print("\n  Manual mode needs at least --weekly-left and --weekly-reset, e.g.:\n\n"
              "    scorch --weekly-left 62 --weekly-reset 11h --window 80 --window-reset 1h\n")
        return 2
    if args.weekly_left is not None and args.weekly_reset is not None:
        now = int(time.time())
        snap = Snapshot(
            now=now,
            five_hour_pct=args.window,
            five_hour_reset=args.window_reset,
            seven_day_pct=100.0 - args.weekly_left,
            seven_day_reset=args.weekly_reset,
        )
        calib = st.load_calibration()
        r = args.r if args.r is not None else (calib.get("r") or calibrate.DEFAULT_R)
        prov = args.r is None and bool(calib.get("r_provisional", True))
        af = habits.active_fraction(st.load_history())
        print(render(snap, compute(snap, r, r_provisional=prov, active_fraction=af), on))
        return 0

    def show_cached():
        data = st.load_state()
        if not _has_usable_snapshot(data):
            print(NO_DATA)
            return False
        snap = Snapshot.from_dict(data.get("snapshot") or {})
        rced = data.get("recommendation") or {}
        af = habits.active_fraction(st.load_history())
        rec = compute(snap, rced.get("r"),
                      r_provisional=rced.get("r_provisional", False),
                      active_fraction=af)
        print(render(snap, rec, on, fc=data.get("forecast")))
        return True

    if args.watch:
        try:
            while True:
                sys.stdout.write("\033[2J\033[H" if on else "\n")
                show_cached()
                time.sleep(10)
        except KeyboardInterrupt:
            return 0
    show_cached()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
